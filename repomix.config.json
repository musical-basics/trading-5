{
  "output": {
    "filePath": "repomix-output.xml"
  },
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "*.db",
      "*.sqlite",
      "*.pyc",
      "__pycache__/**",
      ".venv/**",
      "venv/**",
      "node_modules/**",
      "*.egg-info/**",
      "dist/**",
      "build/**",
      ".git/**",
      ".env",
      ".env.local",
      "*.xml",
      "*.webp",
      "*.png",
      "*.jpg",
      "*.gif",
      ".gemini/**",
      ".agents/**",
      "repomix-output.xml",
      "pnpm-lock.yaml",
      ".next/**",
      "data/**",
      "*.parquet",
      "frontend/tsconfig.tsbuildinfo",
      "docs/**",
      "ui/**",
      "frontend/components/ui/**",
      "frontend/public/**"
    ]
  }
}