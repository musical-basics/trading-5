        if selected_ticker:
            # Load price data
            df_chart = pd.read_sql_query("""
                SELECT date, open, high, low, close, adj_close, volume
                FROM daily_bars WHERE ticker = ? ORDER BY date
            """, conn, params=(selected_ticker,))

            df_chart["date"] = pd.to_datetime(df_chart["date"])

            # ── Plotly Chart ─────────────────────────────────
