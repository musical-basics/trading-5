"""
simulation.py — Level 1 Phase 3: Basic Simulation & Risk Limits

Two responsibilities:
1. Backtest Simulation: For each ticker, calculate cumulative returns when
   holding during signal == 1 periods. Print PnL to console.
2. Today's Live Filter: Isolate today's BUY signals, enforce risk limits:
   - Max 5 open positions
   - $1,000 per trade sizing: floor(1000 / latest_close)
   Returns a list of approved orders.
"""

import sqlite3
import pandas as pd
import math
import os
from datetime import datetime

DB_PATH = os.path.join(os.path.dirname(os.path.abspath(__file__)), "level1_trading.db")

# ── Risk Limit Constants ─────────────────────────────────────
MAX_OPEN_POSITIONS = 5
CAPITAL_PER_TRADE = 1000.0


def simulate_and_filter():
    """
    1. Run a basic paper simulation for each ticker and print PnL.
    2. Filter today's signals through risk limits and return approved orders.
    """
    print("=" * 60)
    print("PHASE 3: Simulation & Risk Limits")
    print("=" * 60)

    conn = sqlite3.connect(DB_PATH)

    # ══════════════════════════════════════════════════════════
    # PART 1: Historical Backtest Simulation
    # ══════════════════════════════════════════════════════════
    print()
    print("  ── Historical Simulation Results ──")

    tickers = pd.read_sql_query(
        "SELECT DISTINCT ticker FROM strategy_signals", conn
    )["ticker"].tolist()

    for ticker in tickers:
        try:
            # Load signals joined with price data
            df = pd.read_sql_query("""
                SELECT s.date, s.signal, b.adj_close
                FROM strategy_signals s
                JOIN daily_bars b ON s.ticker = b.ticker AND s.date = b.date
                WHERE s.ticker = ?
                ORDER BY s.date
            """, conn, params=(ticker,))

            if df.empty:
                continue

            # Calculate daily percentage returns
            df["daily_return"] = df["adj_close"].pct_change()

            # Strategy return: hold when signal == 1 (or when previously signaled BUY)
            # We create a "position" column that stays 1 after a BUY until a SELL
            df["position"] = 0
            position = 0
            positions = []
            for sig in df["signal"]:
                if sig == 1:
                    position = 1
                elif sig == -1:
                    position = 0
                positions.append(position)
            df["position"] = positions

            # Strategy returns: daily return * position (shifted to avoid look-ahead)
            df["strategy_return"] = df["daily_return"] * df["position"].shift(1)

            # Cumulative returns
            strategy_cumulative = (1 + df["strategy_return"].fillna(0)).cumprod().iloc[-1] - 1
            buyhold_cumulative = (1 + df["daily_return"].fillna(0)).cumprod().iloc[-1] - 1

            print(f"  {ticker:6s} | Strategy: {strategy_cumulative:+.1%} | Buy & Hold: {buyhold_cumulative:+.1%}")

        except Exception as e:
            print(f"  {ticker}: Simulation failed — {e}")
            continue

    # ══════════════════════════════════════════════════════════
    # PART 2: Today's Signal Filter & Risk Limits
    # ══════════════════════════════════════════════════════════
    print()
    print("  ── Today's Order Filter ──")

    today_str = datetime.now().strftime("%Y-%m-%d")

    # Get today's BUY signals
    buy_signals = pd.read_sql_query("""
        SELECT s.ticker, s.signal, b.adj_close as latest_price
        FROM strategy_signals s
        JOIN daily_bars b ON s.ticker = b.ticker AND s.date = b.date
        WHERE s.signal = 1 AND s.date = ?
    """, conn, params=(today_str,))

    # Also check for SELL signals for today
    sell_signals = pd.read_sql_query("""
        SELECT s.ticker, s.signal, b.adj_close as latest_price
        FROM strategy_signals s
        JOIN daily_bars b ON s.ticker = b.ticker AND s.date = b.date
        WHERE s.signal = -1 AND s.date = ?
    """, conn, params=(today_str,))

    # Check current open positions (from paper_executions)
    # Count net positions: BUY adds, SELL removes
    positions_df = pd.read_sql_query("""
        SELECT ticker,
               SUM(CASE WHEN action = 'BUY' THEN quantity ELSE -quantity END) as net_shares
        FROM paper_executions
        GROUP BY ticker
        HAVING net_shares > 0
    """, conn)

    current_open = len(positions_df) if not positions_df.empty else 0

    print(f"  Current open positions: {current_open} / {MAX_OPEN_POSITIONS}")

    approved_orders = []

    # Process SELL signals first (free up position slots)
    for _, row in sell_signals.iterrows():
        ticker = row["ticker"]
        price = row["latest_price"]

        # Check if we actually hold this ticker
        held = positions_df[positions_df["ticker"] == ticker] if not positions_df.empty else pd.DataFrame()

        if not held.empty and held.iloc[0]["net_shares"] > 0:
            qty = int(held.iloc[0]["net_shares"])
            approved_orders.append({
                "ticker": ticker,
                "action": "SELL",
                "quantity": qty,
                "price": price,
            })
            current_open -= 1
            print(f"  ✓ SELL {ticker}: {qty} shares @ ${price:.2f} (closing position)")

    # Process BUY signals with risk limits
    for _, row in buy_signals.iterrows():
        ticker = row["ticker"]
        price = row["latest_price"]

        # Limit 1: Max open positions
        if current_open >= MAX_OPEN_POSITIONS:
            print(f"  ✗ REJECTED {ticker}: Max {MAX_OPEN_POSITIONS} positions reached")
            continue

        # Limit 2: $1,000 position sizing
        if price <= 0:
            print(f"  ✗ REJECTED {ticker}: Invalid price ${price}")
            continue

        quantity = math.floor(CAPITAL_PER_TRADE / price)
        if quantity <= 0:
            print(f"  ✗ REJECTED {ticker}: Price ${price:.2f} exceeds ${CAPITAL_PER_TRADE} limit")
            continue

        approved_orders.append({
            "ticker": ticker,
            "action": "BUY",
            "quantity": quantity,
            "price": price,
        })
        current_open += 1
        print(f"  ✓ BUY {ticker}: {quantity} shares @ ${price:.2f} (${quantity * price:.2f})")

    if not buy_signals.empty or not sell_signals.empty:
        print()

    if not approved_orders:
        if buy_signals.empty and sell_signals.empty:
            print(f"  No crossover signals for today ({today_str}). This is normal —")
            print(f"  crossovers are rare events. The pipeline is working correctly.")
        else:
            print(f"  No orders approved after applying risk limits.")
    else:
        print(f"  ✓ {len(approved_orders)} orders approved for routing.")

    print()

    conn.close()
    return approved_orders


if __name__ == "__main__":
    orders = simulate_and_filter()
    print("Approved orders:", orders)
