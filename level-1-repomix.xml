def tactical_math_system(market_df: pl.DataFrame, fund_df: pl.DataFrame, factor_df: pl.DataFrame, lambda_dxy: float) -> pl.DataFrame:
    
    # 1. THE QUERY: Align the components. 
    # Because they share an Apache Arrow backend, this join is incredibly fast.
    components = market_df.join(fund_df, on="entity_id").join(factor_df, on="entity_id")
    
    # 2. THE PROCESSING: Pure Vectorized Math. 
    # No loops. No .apply(). We define the heuristics declaratively.
    enriched = components.with_columns([
        
        # Calculate Enterprise Value: (Price * Shares) + Debt - Cash
        (
            (pl.col("price") * pl.col("shares_out")) + pl.col("total_debt") - pl.col("cash")
        ).alias("enterprise_value"),
        
        # Calculate Return APT: Risk Free Rate (e.g., 4%) + (Beta * Factor Premium)
        (
            0.04 + (pl.col("beta_dxy") * lambda_dxy)
        ).alias("return_apt_score")
    ])
    
    # 3. CASCADING LOGIC: Calculate EV/Sales using the freshly created EV column
    enriched = enriched.with_columns([
        (pl.col("enterprise_value") / pl.col("revenue")).alias("ev_to_sales_score")
    ])
    
    # 4. THE MUTATION: The System strips away the raw data and outputs ONLY 
    # the new "Score Components" to be passed to Phase 3 (XGBoost).
    score_components = enriched.select(["entity_id", "ev_to_sales_score", "return_apt_score"])
    
    return score_components

# ==========================================
