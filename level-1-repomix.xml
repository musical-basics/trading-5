"""
strategy.py — Level 1 Phase 2: Signal Generation

Loads daily_bars from SQLite, calculates 50-day and 200-day Simple Moving
Averages on adj_close, and generates crossover signals:
  1  = BUY  (SMA50 crossed ABOVE SMA200 today)
 -1  = SELL (SMA50 crossed BELOW SMA200 today)
  0  = FLAT (no crossover)

Uses .shift(1) to detect the exact day of crossover.
Saves results to the strategy_signals table.
"""

import sqlite3
import pandas as pd
import os

DB_PATH = os.path.join(os.path.dirname(os.path.abspath(__file__)), "level1_trading.db")


def compute_signals():
    """
    For each ticker in daily_bars, compute SMA 50/200 and crossover signals.
    Save to the strategy_signals table.
    """
    print("=" * 60)
    print("PHASE 2: Signal Generation (SMA Crossover)")
    print("=" * 60)

    conn = sqlite3.connect(DB_PATH)

    # Get all unique tickers
    tickers = pd.read_sql_query(
        "SELECT DISTINCT ticker FROM daily_bars", conn
    )["ticker"].tolist()

    total_signals = 0

    for ticker in tickers:
        try:
            # Load daily bars for this ticker, sorted by date
            df = pd.read_sql_query(
                "SELECT date, adj_close FROM daily_bars WHERE ticker = ? ORDER BY date",
                conn, params=(ticker,)
            )

            if len(df) < 200:
                print(f"  {ticker}: Skipping — only {len(df)} rows (need 200 for SMA 200)")
                continue

            # ── Calculate SMAs using vectorized Pandas ────────────
            df["sma_50"] = df["adj_close"].rolling(window=50).mean()
            df["sma_200"] = df["adj_close"].rolling(window=200).mean()

            # ── Crossover Detection using .shift(1) ──────────────
            # Yesterday's relationship
            prev_above = df["sma_50"].shift(1) > df["sma_200"].shift(1)
            curr_above = df["sma_50"] > df["sma_200"]

            # Signal = 1 on the exact day SMA50 crosses ABOVE SMA200
            # Signal = -1 on the exact day SMA50 crosses BELOW SMA200
            # Signal = 0 otherwise
            df["signal"] = 0
            df.loc[(curr_above) & (~prev_above), "signal"] = 1   # Golden Cross
            df.loc[(~curr_above) & (prev_above), "signal"] = -1  # Death Cross

            # Drop rows where SMA values are NaN (first 199 rows)
            df = df.dropna(subset=["sma_50", "sma_200"])

            # Add ticker column
            df["ticker"] = ticker

            # Prepare for insertion
            signals_df = df[["ticker", "date", "sma_50", "sma_200", "signal"]]

            # Upsert using INSERT OR REPLACE
            cursor = conn.cursor()
            for _, row in signals_df.iterrows():
                cursor.execute("""
                    INSERT OR REPLACE INTO strategy_signals (ticker, date, sma_50, sma_200, signal)
                    VALUES (?, ?, ?, ?, ?)
                """, (row["ticker"], row["date"], row["sma_50"], row["sma_200"], row["signal"]))

            total_signals += len(signals_df)

            # Count crossover events for logging
            buys = (df["signal"] == 1).sum()
            sells = (df["signal"] == -1).sum()
            print(f"  {ticker}: ✓ {len(signals_df)} rows | {buys} BUY crossovers, {sells} SELL crossovers")

        except Exception as e:
            print(f"  {ticker}: FAILED — {e}")
            continue

    conn.commit()
    conn.close()

    print()
    print(f"  ✓ Total signal rows saved: {total_signals}")
    print()


if __name__ == "__main__":
    compute_signals()
