# ==========================================
# PHASE 4a: RECONCILIATION SYSTEM
# ==========================================
def reconciliation_system(target_df: pl.DataFrame, inventory_df: pl.DataFrame, market_df: pl.DataFrame, total_equity: float) -> pl.DataFrame:
    # 1. Join what we WANT, what we HAVE, and the current PRICE
    merged = target_df.join(inventory_df, on="entity_id", how="left").join(market_df, on="entity_id")
    
    # Fill missing inventory with 0 (we don't own it yet)
    merged = merged.with_columns(pl.col("current_shares").fill_null(0))
    
    # 2. Vectorized Delta Calculation
    orders = merged.with_columns([
        # Target Shares = (Equity * Target Weight) / Price
        ((total_equity * pl.col("final_target_weight")) / pl.col("adj_close")).round(0).cast(pl.Int32).alias("target_shares")
    ]).with_columns([
        # Action Intent = Target - Current
        (pl.col("target_shares") - pl.col("current_shares")).alias("action_intent")
    ])
    
    return orders.select(["entity_id", "action_intent", "adj_close"])

# ==========================================
# PHASE 4b: EXECUTION DEFENSE SYSTEM
# ==========================================
def execution_defense_system(orders_df: pl.DataFrame, risk_df: pl.DataFrame) -> pl.DataFrame:
    # Join orders with risk metrics (Borrow Fee, Reddit Hype)
    defense_df = orders_df.join(risk_df, on="entity_id")
    
    # The Trap: Identify dangerous shorts
    is_dangerous_short = (
        (pl.col("action_intent") < 0) &  # We are trying to short
        ((pl.col("borrow_fee_rate") > 0.15) | (pl.col("reddit_hype_spike") == True)) # It's a trap
    )
    
    # Mutate the intent: If dangerous, set order to 0. Otherwise, keep intent.
    safe_orders = defense_df.with_columns([
        pl.when(is_dangerous_short)
