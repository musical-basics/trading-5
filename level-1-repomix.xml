# ==========================================
# PHASE 3a: XGBOOST SYNTHESIS SYSTEM
# ==========================================
def xgboost_synthesis_system(score_components: pl.DataFrame, model: xgb.Booster) -> pl.DataFrame:
    # 1. THE QUERY: Drop rows with nulls (stale/broken data) before feeding to ML
    valid_scores = score_components.drop_nulls()
    
    # 2. THE PREDICTION: XGBoost natively accepts Polars/Arrow data.
    # We extract the feature columns and predict the target capital allocation.
    features = valid_scores.select(["ev_to_sales_score", "return_apt_score"])
    
    # Mocking the prediction for this example (e.g., outputs desired % of portfolio)
    # In reality: raw_weights = model.predict(xgb.DMatrix(features))
    raw_weights = np.array([0.08, 0.12]) # E.g., wants 8% in Entity 1, 12% in Entity 2
    
    # 3. THE MUTATION: Attach the raw intent to our pipeline
    intent_df = valid_scores.with_columns(
        pl.Series("raw_target_weight", raw_weights)
    )
    return intent_df


# ==========================================
# PHASE 3b: RISK APT SHIELD SYSTEM
# ==========================================
def risk_apt_system(intent_df: pl.DataFrame, cov_matrix: np.ndarray, max_mcr: float = 0.05) -> pl.DataFrame:
    # 1. THE HANDOFF: Extract weights into a flat NumPy array for matrix algebra
    w = intent_df["raw_target_weight"].to_numpy()
    
    # 2. THE MATH: Calculate Portfolio Variance and MCR 
    # Formula: Variance = w^T * Sigma * w
    port_variance = np.dot(w.T, np.dot(cov_matrix, w))
    port_volatility = np.sqrt(port_variance)
    
    # Formula: MCR_i = (Sigma * w)_i / Volatility
    marginal_contrib = np.dot(cov_matrix, w) / port_volatility
    
    # 3. THE HEURISTIC RULE: If MCR > max_mcr, calculate a scale-down factor.
    # We use np.where to apply this across the entire array instantly.
    scale_factors = np.where(
        marginal_contrib > max_mcr, 
        max_mcr / marginal_contrib,  # Scale down if breached
        1.0                          # Leave alone if safe
    )
    
    # 4. THE MUTATION: Apply the scale factor and output the final, safe weights
    safe_weights = w * scale_factors
    
    final_portfolio = intent_df.with_columns(
        pl.Series("final_target_weight", safe_weights)
    ).select(["entity_id", "final_target_weight"])
    
    return final_portfolio


